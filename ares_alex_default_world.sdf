<?xml version="1.0" ?>
<sdf version="1.8">
  <world name="ares_world">

    <physics name="1ms" type="ignored">
      <max_step_size>0.001</max_step_size>
      <real_time_update_rate>1000</real_time_update_rate>
    </physics>

    <!-- GPS coordinates — required for ArduPilot EKF compass/heading simulation -->
    <spherical_coordinates>
      <latitude_deg>-35.363262</latitude_deg>
      <longitude_deg>149.165237</longitude_deg>
      <elevation>584</elevation>
      <heading_deg>0</heading_deg>
      <surface_model>EARTH_WGS84</surface_model>
    </spherical_coordinates>

    <!-- World-level plugins ONLY -->
    <plugin filename="gz-sim-physics-system" name="gz::sim::systems::Physics"/>
    <plugin filename="gz-sim-navsat-system" name="gz::sim::systems::NavSat"/>
    <plugin filename="gz-sim-user-commands-system" name="gz::sim::systems::UserCommands"/>
    <plugin filename="gz-sim-scene-broadcaster-system" name="gz::sim::systems::SceneBroadcaster"/>
    <plugin filename="gz-sim-sensors-system" name="gz::sim::systems::Sensors">
      <render_engine>ogre2</render_engine>
    </plugin>
    <plugin filename="gz-sim-imu-system" name="gz::sim::systems::Imu"/>

    <scene>
      <ambient>0.6 0.4 0.4 1</ambient>
      <background>0.2 0.5 0.8 1</background>
      <shadows>false</shadows>
    </scene>

    <light type="directional" name="sun">
      <cast_shadows>false</cast_shadows>
      <pose>0 0 100 0 0 0</pose>
      <diffuse>0.9 0.9 0.9 1</diffuse>
      <specular>0.3 0.3 0.3 1</specular>
      <direction>-0.5 0.1 -0.9</direction>
    </light>

    <model name="ground_plane">
      <static>true</static>
      <link name="link">
        <collision name="collision">
          <geometry><plane><normal>0 0 1</normal><size>200 200</size></plane></geometry>
        </collision>
        <visual name="visual">
          <geometry><plane><normal>0 0 1</normal><size>200 200</size></plane></geometry>
          <material><ambient>0.2 0.4 0.2 1</ambient><diffuse>0.2 0.5 0.2 1</diffuse></material>
        </visual>
      </link>
    </model>

    <!-- HILLS -->
    <model name="hill_1">
      <static>true</static><pose>20 10 0 0 0 0</pose>
      <link name="link">
        <collision name="col"><geometry><sphere><radius>6</radius></sphere></geometry><pose>0 0 -4 0 0 0</pose></collision>
        <visual name="vis"><geometry><sphere><radius>6</radius></sphere></geometry><pose>0 0 -4 0 0 0</pose>
          <material><ambient>0.3 0.5 0.2 1</ambient><diffuse>0.3 0.6 0.2 1</diffuse></material></visual>
      </link>
    </model>
    <model name="hill_2">
      <static>true</static><pose>-15 25 0 0 0 0</pose>
      <link name="link">
        <collision name="col"><geometry><sphere><radius>8</radius></sphere></geometry><pose>0 0 -6 0 0 0</pose></collision>
        <visual name="vis"><geometry><sphere><radius>8</radius></sphere></geometry><pose>0 0 -6 0 0 0</pose>
          <material><ambient>0.3 0.5 0.2 1</ambient><diffuse>0.3 0.6 0.2 1</diffuse></material></visual>
      </link>
    </model>

    <!-- GATE 1 - orange -->
    <model name="gate_1_left_post"><static>true</static><pose>10 -5 0 0 0 0</pose>
      <link name="link"><collision name="col"><geometry><cylinder><radius>0.15</radius><length>4</length></cylinder></geometry><pose>0 0 2 0 0 0</pose></collision>
        <visual name="vis"><geometry><cylinder><radius>0.15</radius><length>4</length></cylinder></geometry><pose>0 0 2 0 0 0</pose><material><ambient>1 0.4 0 1</ambient><diffuse>1 0.4 0 1</diffuse></material></visual></link>
    </model>
    <model name="gate_1_right_post"><static>true</static><pose>10 5 0 0 0 0</pose>
      <link name="link"><collision name="col"><geometry><cylinder><radius>0.15</radius><length>4</length></cylinder></geometry><pose>0 0 2 0 0 0</pose></collision>
        <visual name="vis"><geometry><cylinder><radius>0.15</radius><length>4</length></cylinder></geometry><pose>0 0 2 0 0 0</pose><material><ambient>1 0.4 0 1</ambient><diffuse>1 0.4 0 1</diffuse></material></visual></link>
    </model>
    <model name="gate_1_top_bar"><static>true</static><pose>10 0 4 0 0 0</pose>
      <link name="link"><collision name="col"><geometry><box><size>0.3 10.3 0.3</size></box></geometry></collision>
        <visual name="vis"><geometry><box><size>0.3 10.3 0.3</size></box></geometry><material><ambient>1 0.4 0 1</ambient><diffuse>1 0.4 0 1</diffuse></material></visual></link>
    </model>

    <!-- GATE 2 - yellow -->
    <model name="gate_4_left_post"><static>true</static><pose>-10 20 0 0 0 0</pose>
      <link name="link"><collision name="col"><geometry><cylinder><radius>0.15</radius><length>4</length></cylinder></geometry><pose>0 0 2 0 0 0</pose></collision>
        <visual name="vis"><geometry><cylinder><radius>0.15</radius><length>4</length></cylinder></geometry><pose>0 0 2 0 0 0</pose><material><ambient>1 0.9 0 1</ambient><diffuse>1 0.9 0 1</diffuse></material></visual></link>
    </model>
    <model name="gate_4_right_post"><static>true</static><pose>-10 28 0 0 0 0</pose>
      <link name="link"><collision name="col"><geometry><cylinder><radius>0.15</radius><length>4</length></cylinder></geometry><pose>0 0 2 0 0 0</pose></collision>
        <visual name="vis"><geometry><cylinder><radius>0.15</radius><length>4</length></cylinder></geometry><pose>0 0 2 0 0 0</pose><material><ambient>1 0.9 0 1</ambient><diffuse>1 0.9 0 1</diffuse></material></visual></link>
    </model>
    <model name="gate_4_top_bar"><static>true</static><pose>-10 24 4 0 0 0</pose>
      <link name="link"><collision name="col"><geometry><box><size>0.3 8.3 0.3</size></box></geometry></collision>
        <visual name="vis"><geometry><box><size>0.3 8.3 0.3</size></box></geometry><material><ambient>1 0.9 0 1</ambient><diffuse>1 0.9 0 1</diffuse></material></visual></link>
    </model>

    <!-- WALL OBSTACLES -->
    <model name="slalom_wall_left"><static>true</static><pose>8 -8 1.5 0 0 0</pose>
      <link name="link"><collision name="col"><geometry><box><size>0.3 6 3</size></box></geometry></collision>
        <visual name="vis"><geometry><box><size>0.3 6 3</size></box></geometry><material><ambient>0.6 0.1 0.1 1</ambient><diffuse>0.7 0.1 0.1 1</diffuse></material></visual></link>
    </model>
    <model name="slalom_wall_right"><static>true</static><pose>8 6 1.5 0 0 0</pose>
      <link name="link"><collision name="col"><geometry><box><size>0.3 6 3</size></box></geometry></collision>
        <visual name="vis"><geometry><box><size>0.3 6 3</size></box></geometry><material><ambient>0.6 0.1 0.1 1</ambient><diffuse>0.7 0.1 0.1 1</diffuse></material></visual></link>
    </model>
    <model name="tunnel_left_wall"><static>true</static><pose>22 -3 1 0 0 0</pose>
      <link name="link"><collision name="col"><geometry><box><size>8 0.3 2</size></box></geometry></collision>
        <visual name="vis"><geometry><box><size>8 0.3 2</size></box></geometry><material><ambient>0.5 0.5 0.5 1</ambient><diffuse>0.6 0.6 0.6 1</diffuse></material></visual></link>
    </model>
    <model name="tunnel_right_wall"><static>true</static><pose>22 3 1 0 0 0</pose>
      <link name="link"><collision name="col"><geometry><box><size>8 0.3 2</size></box></geometry></collision>
        <visual name="vis"><geometry><box><size>8 0.3 2</size></box></geometry><material><ambient>0.5 0.5 0.5 1</ambient><diffuse>0.6 0.6 0.6 1</diffuse></material></visual></link>
    </model>
    <model name="tunnel_ceiling"><static>true</static><pose>22 0 2 0 0 0</pose>
      <link name="link"><collision name="col"><geometry><box><size>8 6.3 0.3</size></box></geometry></collision>
        <visual name="vis"><geometry><box><size>8 6.3 0.3</size></box></geometry><material><ambient>0.4 0.4 0.4 1</ambient><diffuse>0.5 0.5 0.5 1</diffuse></material></visual></link>
    </model>
    <model name="pillar_1"><static>true</static><pose>-5 10 2 0 0 0</pose>
      <link name="link"><collision name="col"><geometry><cylinder><radius>0.4</radius><length>4</length></cylinder></geometry></collision>
        <visual name="vis"><geometry><cylinder><radius>0.4</radius><length>4</length></cylinder></geometry><material><ambient>0.7 0.5 0.1 1</ambient><diffuse>0.8 0.6 0.1 1</diffuse></material></visual></link>
    </model>
    <model name="pillar_2"><static>true</static><pose>5 15 2 0 0 0</pose>
      <link name="link"><collision name="col"><geometry><cylinder><radius>0.4</radius><length>4</length></cylinder></geometry></collision>
        <visual name="vis"><geometry><cylinder><radius>0.4</radius><length>4</length></cylinder></geometry><material><ambient>0.7 0.5 0.1 1</ambient><diffuse>0.8 0.6 0.1 1</diffuse></material></visual></link>
    </model>
    <model name="pillar_3"><static>true</static><pose>-3 -12 2 0 0 0</pose>
      <link name="link"><collision name="col"><geometry><cylinder><radius>0.4</radius><length>4</length></cylinder></geometry></collision>
        <visual name="vis"><geometry><cylinder><radius>0.4</radius><length>4</length></cylinder></geometry><material><ambient>0.7 0.5 0.1 1</ambient><diffuse>0.8 0.6 0.1 1</diffuse></material></visual></link>
    </model>

    <!-- ============================================================ -->
    <!-- TERRAIN FOLLOWING COURSE                                     -->
    <!-- Path: spawn(0,0) → slalom(X=8) → gate(X=10) → tunnel(X=22) -->
    <!--       → ramp up(X=35-42) → platform(X=42-52) → ramp dn(X=52-59) -->
    <!-- Drone flies at 2m AGL throughout                             -->
    <!-- ============================================================ -->

    <!-- Ground track: yellow path strip along Y=0 showing the route -->
    <model name="track_strip"><static>true</static><pose>29.5 0 0.01 0 0 0</pose>
      <link name="link">
        <visual name="vis"><geometry><box><size>59 1.5 0.02</size></box></geometry>
          <material><ambient>0.9 0.8 0.0 1</ambient><diffuse>1.0 0.9 0.0 1</diffuse></material></visual>
      </link>
    </model>

    <!-- Ramp up: X=35 to X=42, rises from Z=0 to Z=2m (angle ~15.9 deg = 0.2783 rad) -->
    <!-- Box along slope: sqrt(7^2 + 2^2) = 7.28m long, width 8m, thick 0.4m -->
    <model name="terrain_ramp_up"><static>true</static><pose>38.5 0 1.0 0 -0.2783 0</pose>
      <link name="link">
        <collision name="col"><geometry><box><size>7.28 8 0.4</size></box></geometry></collision>
        <visual name="vis"><geometry><box><size>7.28 8 0.4</size></box></geometry>
          <material><ambient>0.72 0.60 0.35 1</ambient><diffuse>0.80 0.68 0.40 1</diffuse></material></visual>
      </link>
    </model>
    <!-- Fill under ramp so no gap at base -->
    <model name="terrain_ramp_up_fill"><static>true</static><pose>37.5 0 0.5 0 0 0</pose>
      <link name="link">
        <collision name="col"><geometry><box><size>5 8 1.0</size></box></geometry></collision>
        <visual name="vis"><geometry><box><size>5 8 1.0</size></box></geometry>
          <material><ambient>0.68 0.56 0.32 1</ambient><diffuse>0.76 0.64 0.38 1</diffuse></material></visual>
      </link>
    </model>

    <!-- Elevated platform: X=42 to X=52, Z=0 to Z=2m solid block -->
    <model name="terrain_platform"><static>true</static><pose>47 0 1.0 0 0 0</pose>
      <link name="link">
        <collision name="col"><geometry><box><size>10 8 2.0</size></box></geometry></collision>
        <visual name="vis"><geometry><box><size>10 8 2.0</size></box></geometry>
          <material><ambient>0.65 0.53 0.30 1</ambient><diffuse>0.74 0.62 0.36 1</diffuse></material></visual>
      </link>
    </model>

    <!-- Ramp down: X=52 to X=59, falls from Z=2m to Z=0 -->
    <model name="terrain_ramp_down"><static>true</static><pose>55.5 0 1.0 0 0.2783 0</pose>
      <link name="link">
        <collision name="col"><geometry><box><size>7.28 8 0.4</size></box></geometry></collision>
        <visual name="vis"><geometry><box><size>7.28 8 0.4</size></box></geometry>
          <material><ambient>0.72 0.60 0.35 1</ambient><diffuse>0.80 0.68 0.40 1</diffuse></material></visual>
      </link>
    </model>
    <model name="terrain_ramp_down_fill"><static>true</static><pose>56.5 0 0.5 0 0 0</pose>
      <link name="link">
        <collision name="col"><geometry><box><size>5 8 1.0</size></box></geometry></collision>
        <visual name="vis"><geometry><box><size>5 8 1.0</size></box></geometry>
          <material><ambient>0.68 0.56 0.32 1</ambient><diffuse>0.76 0.64 0.38 1</diffuse></material></visual>
      </link>
    </model>

    <!-- Waypoint poles: bright blue cylinders at 2m AGL along the path -->
    <!-- Each pole = radius 0.05m, length 0.6m, positioned at drone flight height -->
    <model name="wp_start"><static>true</static><pose>0 0 2.3 0 0 0</pose>
      <link name="link">
        <visual name="vis"><geometry><cylinder><radius>0.07</radius><length>0.6</length></cylinder></geometry>
          <material><ambient>0.0 0.8 0.0 1</ambient><diffuse>0.0 1.0 0.0 1</diffuse></material></visual>
      </link>
    </model>
    <model name="wp_1"><static>true</static><pose>10 0 2.3 0 0 0</pose>
      <link name="link">
        <visual name="vis"><geometry><cylinder><radius>0.07</radius><length>0.6</length></cylinder></geometry>
          <material><ambient>0.0 0.4 0.9 1</ambient><diffuse>0.0 0.5 1.0 1</diffuse></material></visual>
      </link>
    </model>
    <model name="wp_2"><static>true</static><pose>22 0 2.3 0 0 0</pose>
      <link name="link">
        <visual name="vis"><geometry><cylinder><radius>0.07</radius><length>0.6</length></cylinder></geometry>
          <material><ambient>0.0 0.4 0.9 1</ambient><diffuse>0.0 0.5 1.0 1</diffuse></material></visual>
      </link>
    </model>
    <model name="wp_3"><static>true</static><pose>35 0 2.3 0 0 0</pose>
      <link name="link">
        <visual name="vis"><geometry><cylinder><radius>0.07</radius><length>0.6</length></cylinder></geometry>
          <material><ambient>0.0 0.4 0.9 1</ambient><diffuse>0.0 0.5 1.0 1</diffuse></material></visual>
      </link>
    </model>
    <!-- wp_4 and wp_5 are 2m above the platform surface (Z=2+2=4m) -->
    <model name="wp_4"><static>true</static><pose>42 0 4.3 0 0 0</pose>
      <link name="link">
        <visual name="vis"><geometry><cylinder><radius>0.07</radius><length>0.6</length></cylinder></geometry>
          <material><ambient>0.0 0.4 0.9 1</ambient><diffuse>0.0 0.5 1.0 1</diffuse></material></visual>
      </link>
    </model>
    <model name="wp_5"><static>true</static><pose>47 0 4.3 0 0 0</pose>
      <link name="link">
        <visual name="vis"><geometry><cylinder><radius>0.07</radius><length>0.6</length></cylinder></geometry>
          <material><ambient>0.0 0.4 0.9 1</ambient><diffuse>0.0 0.5 1.0 1</diffuse></material></visual>
      </link>
    </model>
    <model name="wp_6"><static>true</static><pose>52 0 4.3 0 0 0</pose>
      <link name="link">
        <visual name="vis"><geometry><cylinder><radius>0.07</radius><length>0.6</length></cylinder></geometry>
          <material><ambient>0.0 0.4 0.9 1</ambient><diffuse>0.0 0.5 1.0 1</diffuse></material></visual>
      </link>
    </model>
    <model name="wp_7"><static>true</static><pose>59 0 2.3 0 0 0</pose>
      <link name="link">
        <visual name="vis"><geometry><cylinder><radius>0.07</radius><length>0.6</length></cylinder></geometry>
          <material><ambient>0.0 0.4 0.9 1</ambient><diffuse>0.0 0.5 1.0 1</diffuse></material></visual>
      </link>
    </model>
    <!-- End marker: red pole -->
    <model name="wp_end"><static>true</static><pose>65 0 2.3 0 0 0</pose>
      <link name="link">
        <visual name="vis"><geometry><cylinder><radius>0.07</radius><length>0.6</length></cylinder></geometry>
          <material><ambient>0.9 0.0 0.0 1</ambient><diffuse>1.0 0.0 0.0 1</diffuse></material></visual>
      </link>
    </model>

    <!-- ============================================================ -->
    <!-- QUADROTOR - all motor/control plugins are INSIDE this model tag -->
    <model name="quadrotor">
      <pose>0 0 0.2 0 0 0</pose>

      <link name="base_link">
        <inertial>
          <mass>1.95</mass>
          <inertia>
            <ixx>0.0451832</ixx><ixy>0</ixy><ixz>0</ixz>
            <iyy>0.0596608</iyy><iyz>0</iyz>
            <izz>0.0910</izz>
          </inertia>
        </inertial>
        <collision name="body_col"><geometry><box><size>0.3937 0.3937 0.09271</size></box></geometry></collision>
        <visual name="body_vis"><geometry><box><size>0.3937 0.3937 0.09271</size></box></geometry>
          <material><ambient>0.1 0.1 0.1 1</ambient><diffuse>0.2 0.2 0.2 1</diffuse></material></visual>

        <sensor name="imu_sensor" type="imu">
          <always_on>true</always_on><update_rate>400</update_rate>
          <imu>
            <angular_velocity>
              <x><noise type="none"/></x>
              <y><noise type="none"/></y>
              <z><noise type="none"/></z>
            </angular_velocity>
            <linear_acceleration>
              <x><noise type="none"/></x>
              <y><noise type="none"/></y>
              <z><noise type="none"/></z>
            </linear_acceleration>
          </imu>
        </sensor>

        <sensor name="front_camera" type="camera">
          <always_on>true</always_on><update_rate>30</update_rate>
          <pose>-0.1905 0 0.02667 0 0 0</pose>
          <camera>
            <horizontal_fov>1.5708</horizontal_fov>
            <image><width>640</width><height>480</height><format>R8G8B8</format></image>
            <clip><near>0.1</near><far>100</far></clip>
          </camera>
          <topic>/drone/camera/front</topic>
        </sensor>

      </link>
      <link name="rotor_fl">
        <pose>0.15875 0.166878 0.093345 0 0 0</pose>
        <inertial><mass>0.094</mass><inertia><ixx>9.75e-7</ixx><ixy>0</ixy><ixz>0</ixz><iyy>0.000166704</iyy><iyz>0</iyz><izz>0.000167604</izz></inertia></inertial>
        <collision name="col"><geometry><cylinder><radius>0.128</radius><length>0.005</length></cylinder></geometry></collision>
        <visual name="vis"><geometry><cylinder><radius>0.128</radius><length>0.005</length></cylinder></geometry>
          <material><ambient>0.1 0.1 0.1 0.5</ambient><diffuse>0.1 0.1 0.1 0.5</diffuse></material></visual>
      </link>
      <joint name="rotor_fl_joint" type="revolute">
        <parent>base_link</parent><child>rotor_fl</child>
        <axis><xyz>0 0 1</xyz><limit><lower>-1e+16</lower><upper>1e+16</upper></limit><dynamics><damping>0.004</damping></dynamics></axis>
      </joint>

      <link name="rotor_fr">
        <pose>0.15875 -0.166878 0.093345 0 0 0</pose>
        <inertial><mass>0.094</mass><inertia><ixx>9.75e-7</ixx><ixy>0</ixy><ixz>0</ixz><iyy>0.000166704</iyy><iyz>0</iyz><izz>0.000167604</izz></inertia></inertial>
        <collision name="col"><geometry><cylinder><radius>0.128</radius><length>0.005</length></cylinder></geometry></collision>
        <visual name="vis"><geometry><cylinder><radius>0.128</radius><length>0.005</length></cylinder></geometry>
          <material><ambient>0.1 0.1 0.1 0.5</ambient><diffuse>0.1 0.1 0.1 0.5</diffuse></material></visual>
      </link>
      <joint name="rotor_fr_joint" type="revolute">
        <parent>base_link</parent><child>rotor_fr</child>
        <axis><xyz>0 0 1</xyz><limit><lower>-1e+16</lower><upper>1e+16</upper></limit><dynamics><damping>0.004</damping></dynamics></axis>
      </joint>

      <link name="rotor_rl">
        <pose>-0.15875 0.166878 0.093345 0 0 0</pose>
        <inertial><mass>0.094</mass><inertia><ixx>9.75e-7</ixx><ixy>0</ixy><ixz>0</ixz><iyy>0.000166704</iyy><iyz>0</iyz><izz>0.000167604</izz></inertia></inertial>
        <collision name="col"><geometry><cylinder><radius>0.128</radius><length>0.005</length></cylinder></geometry></collision>
        <visual name="vis"><geometry><cylinder><radius>0.128</radius><length>0.005</length></cylinder></geometry>
          <material><ambient>0.1 0.1 0.1 0.5</ambient><diffuse>0.1 0.1 0.1 0.5</diffuse></material></visual>
      </link>
      <joint name="rotor_rl_joint" type="revolute">
        <parent>base_link</parent><child>rotor_rl</child>
        <axis><xyz>0 0 1</xyz><limit><lower>-1e+16</lower><upper>1e+16</upper></limit><dynamics><damping>0.004</damping></dynamics></axis>
      </joint>

      <link name="rotor_rr">
        <pose>-0.15875 -0.166878 0.093345 0 0 0</pose>
        <inertial><mass>0.094</mass><inertia><ixx>9.75e-7</ixx><ixy>0</ixy><ixz>0</ixz><iyy>0.000166704</iyy><iyz>0</iyz><izz>0.000167604</izz></inertia></inertial>
        <collision name="col"><geometry><cylinder><radius>0.128</radius><length>0.005</length></cylinder></geometry></collision>
        <visual name="vis"><geometry><cylinder><radius>0.128</radius><length>0.005</length></cylinder></geometry>
          <material><ambient>0.1 0.1 0.1 0.5</ambient><diffuse>0.1 0.1 0.1 0.5</diffuse></material></visual>
      </link>
      <joint name="rotor_rr_joint" type="revolute">
        <parent>base_link</parent><child>rotor_rr</child>
        <axis><xyz>0 0 1</xyz><limit><lower>-1e+16</lower><upper>1e+16</upper></limit><dynamics><damping>0.004</damping></dynamics></axis>
      </joint>

      <!-- LiftDrag aerodynamics — 2 blades per rotor, matching official iris_with_ardupilot.
           CCW rotors (fr, rl): forward=0 1 0 / 0 -1 0
           CW  rotors (fl, rr): forward=0 -1 0 / 0 1 0 -->

      <!-- rotor_fr (ch0, CCW, +838) -->
      <plugin filename="gz-sim-lift-drag-system" name="gz::sim::systems::LiftDrag">
        <a0>0.3</a0><alpha_stall>1.4</alpha_stall><cla>4.2500</cla><cda>0.10</cda><cma>0.0</cma>
        <cla_stall>-0.025</cla_stall><cda_stall>0.0</cda_stall><cma_stall>0.0</cma_stall>
        <area>0.002</area><air_density>1.2041</air_density>
        <cp>0.084 0 0</cp><forward>0 1 0</forward><upward>0 0 1</upward>
        <link_name>rotor_fr</link_name>
      </plugin>
      <plugin filename="gz-sim-lift-drag-system" name="gz::sim::systems::LiftDrag">
        <a0>0.3</a0><alpha_stall>1.4</alpha_stall><cla>4.2500</cla><cda>0.10</cda><cma>0.0</cma>
        <cla_stall>-0.025</cla_stall><cda_stall>0.0</cda_stall><cma_stall>0.0</cma_stall>
        <area>0.002</area><air_density>1.2041</air_density>
        <cp>-0.084 0 0</cp><forward>0 -1 0</forward><upward>0 0 1</upward>
        <link_name>rotor_fr</link_name>
      </plugin>

      <!-- rotor_rl (ch1, CCW, +838) -->
      <plugin filename="gz-sim-lift-drag-system" name="gz::sim::systems::LiftDrag">
        <a0>0.3</a0><alpha_stall>1.4</alpha_stall><cla>4.2500</cla><cda>0.10</cda><cma>0.0</cma>
        <cla_stall>-0.025</cla_stall><cda_stall>0.0</cda_stall><cma_stall>0.0</cma_stall>
        <area>0.002</area><air_density>1.2041</air_density>
        <cp>0.084 0 0</cp><forward>0 1 0</forward><upward>0 0 1</upward>
        <link_name>rotor_rl</link_name>
      </plugin>
      <plugin filename="gz-sim-lift-drag-system" name="gz::sim::systems::LiftDrag">
        <a0>0.3</a0><alpha_stall>1.4</alpha_stall><cla>4.2500</cla><cda>0.10</cda><cma>0.0</cma>
        <cla_stall>-0.025</cla_stall><cda_stall>0.0</cda_stall><cma_stall>0.0</cma_stall>
        <area>0.002</area><air_density>1.2041</air_density>
        <cp>-0.084 0 0</cp><forward>0 -1 0</forward><upward>0 0 1</upward>
        <link_name>rotor_rl</link_name>
      </plugin>

      <!-- rotor_fl (ch2, CW, -838) -->
      <plugin filename="gz-sim-lift-drag-system" name="gz::sim::systems::LiftDrag">
        <a0>0.3</a0><alpha_stall>1.4</alpha_stall><cla>4.2500</cla><cda>0.10</cda><cma>0.0</cma>
        <cla_stall>-0.025</cla_stall><cda_stall>0.0</cda_stall><cma_stall>0.0</cma_stall>
        <area>0.002</area><air_density>1.2041</air_density>
        <cp>0.084 0 0</cp><forward>0 -1 0</forward><upward>0 0 1</upward>
        <link_name>rotor_fl</link_name>
      </plugin>
      <plugin filename="gz-sim-lift-drag-system" name="gz::sim::systems::LiftDrag">
        <a0>0.3</a0><alpha_stall>1.4</alpha_stall><cla>4.2500</cla><cda>0.10</cda><cma>0.0</cma>
        <cla_stall>-0.025</cla_stall><cda_stall>0.0</cda_stall><cma_stall>0.0</cma_stall>
        <area>0.002</area><air_density>1.2041</air_density>
        <cp>-0.084 0 0</cp><forward>0 1 0</forward><upward>0 0 1</upward>
        <link_name>rotor_fl</link_name>
      </plugin>

      <!-- rotor_rr (ch3, CW, -838) -->
      <plugin filename="gz-sim-lift-drag-system" name="gz::sim::systems::LiftDrag">
        <a0>0.3</a0><alpha_stall>1.4</alpha_stall><cla>4.2500</cla><cda>0.10</cda><cma>0.0</cma>
        <cla_stall>-0.025</cla_stall><cda_stall>0.0</cda_stall><cma_stall>0.0</cma_stall>
        <area>0.002</area><air_density>1.2041</air_density>
        <cp>0.084 0 0</cp><forward>0 -1 0</forward><upward>0 0 1</upward>
        <link_name>rotor_rr</link_name>
      </plugin>
      <plugin filename="gz-sim-lift-drag-system" name="gz::sim::systems::LiftDrag">
        <a0>0.3</a0><alpha_stall>1.4</alpha_stall><cla>4.2500</cla><cda>0.10</cda><cma>0.0</cma>
        <cla_stall>-0.025</cla_stall><cda_stall>0.0</cda_stall><cma_stall>0.0</cma_stall>
        <area>0.002</area><air_density>1.2041</air_density>
        <cp>-0.084 0 0</cp><forward>0 1 0</forward><upward>0 0 1</upward>
        <link_name>rotor_rr</link_name>
      </plugin>

      <!-- ApplyJointForce — required for ArduPilotPlugin PID joint force control -->
      <plugin filename="gz-sim-apply-joint-force-system" name="gz::sim::systems::ApplyJointForce">
        <joint_name>rotor_fr_joint</joint_name>
      </plugin>
      <plugin filename="gz-sim-apply-joint-force-system" name="gz::sim::systems::ApplyJointForce">
        <joint_name>rotor_rl_joint</joint_name>
      </plugin>
      <plugin filename="gz-sim-apply-joint-force-system" name="gz::sim::systems::ApplyJointForce">
        <joint_name>rotor_fl_joint</joint_name>
      </plugin>
      <plugin filename="gz-sim-apply-joint-force-system" name="gz::sim::systems::ApplyJointForce">
        <joint_name>rotor_rr_joint</joint_name>
      </plugin>

      <!-- ArduPilot Gazebo plugin: receives PWM from ArduPilot SITL via UDP
           and sends back sensor data.
           Requires: https://github.com/ArduPilot/ardupilot_gazebo
           SITL must be started with:
             sim_vehicle.py -v ArduCopter -f gazebo-iris --model JSON --map --console -->
      <plugin filename="ArduPilotPlugin" name="ArduPilotPlugin">
        <fdm_addr>127.0.0.1</fdm_addr>
        <fdm_port_in>9002</fdm_port_in>
        <connectionTimeoutMaxCount>5</connectionTimeoutMaxCount>
        <lock_step>1</lock_step>
        <no_time_sync>1</no_time_sync>
        <have_32_channels>0</have_32_channels>
        <modelXYZToAirplaneXForwardZDown degrees="true">0 0 0 180 0 0</modelXYZToAirplaneXForwardZDown>
        <gazeboXYZToNED degrees="true">0 0 0 180 0 90</gazeboXYZToNED>
        <!-- imuName is scoped relative to model: link::sensor -->
        <imuName>base_link::imu_sensor</imuName>
        <!-- ch0 = Motor 1 = Front-Right (CCW, +838) — matches official iris rotor_0 -->
        <control channel="0">
          <jointName>rotor_fr_joint</jointName>
          <useForce>1</useForce>
          <multiplier>838</multiplier>
          <offset>0</offset>
          <servo_min>1100</servo_min>
          <servo_max>1900</servo_max>
          <type>VELOCITY</type>
          <p_gain>0.20</p_gain>
          <i_gain>0</i_gain>
          <d_gain>0</d_gain>
          <i_max>0</i_max>
          <i_min>0</i_min>
          <cmd_max>2.5</cmd_max>
          <cmd_min>-2.5</cmd_min>
          <controlVelocitySlowdownSim>1</controlVelocitySlowdownSim>
        </control>
        <!-- ch1 = Motor 2 = Rear-Left (CCW, +838) — diagonal with FR, matches official iris rotor_1 -->
        <control channel="1">
          <jointName>rotor_rl_joint</jointName>
          <useForce>1</useForce>
          <multiplier>838</multiplier>
          <offset>0</offset>
          <servo_min>1100</servo_min>
          <servo_max>1900</servo_max>
          <type>VELOCITY</type>
          <p_gain>0.20</p_gain>
          <i_gain>0</i_gain>
          <d_gain>0</d_gain>
          <i_max>0</i_max>
          <i_min>0</i_min>
          <cmd_max>2.5</cmd_max>
          <cmd_min>-2.5</cmd_min>
          <controlVelocitySlowdownSim>1</controlVelocitySlowdownSim>
        </control>
        <!-- ch2 = Motor 3 = Front-Left (CW, -838) — matches official iris rotor_2 -->
        <control channel="2">
          <jointName>rotor_fl_joint</jointName>
          <useForce>1</useForce>
          <multiplier>-838</multiplier>
          <offset>0</offset>
          <servo_min>1100</servo_min>
          <servo_max>1900</servo_max>
          <type>VELOCITY</type>
          <p_gain>0.20</p_gain>
          <i_gain>0</i_gain>
          <d_gain>0</d_gain>
          <i_max>0</i_max>
          <i_min>0</i_min>
          <cmd_max>2.5</cmd_max>
          <cmd_min>-2.5</cmd_min>
          <controlVelocitySlowdownSim>1</controlVelocitySlowdownSim>
        </control>
        <!-- ch3 = Motor 4 = Rear-Right (CW, -838) — diagonal with FL, matches official iris rotor_3 -->
        <control channel="3">
          <jointName>rotor_rr_joint</jointName>
          <useForce>1</useForce>
          <multiplier>-838</multiplier>
          <offset>0</offset>
          <servo_min>1100</servo_min>
          <servo_max>1900</servo_max>
          <type>VELOCITY</type>
          <p_gain>0.20</p_gain>
          <i_gain>0</i_gain>
          <d_gain>0</d_gain>
          <i_max>0</i_max>
          <i_min>0</i_min>
          <cmd_max>2.5</cmd_max>
          <cmd_min>-2.5</cmd_min>
          <controlVelocitySlowdownSim>1</controlVelocitySlowdownSim>
        </control>
      </plugin>

    </model>

  </world>
</sdf>
